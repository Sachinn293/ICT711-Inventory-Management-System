package ims;

import java.util.ArrayList;
import java.util.InputMismatchException;
import java.util.Scanner;

// Main class - entry point of the Inventory Management System
// Handles the text-based menu and user interaction
public class Main {

    private static InventoryManager manager = new InventoryManager();
    private static Scanner scanner = new Scanner(System.in);
    private static final String DATA_FILE = "data/inventory.csv";

    public static void main(String[] args) {
        System.out.println("==========================================");
        System.out.println("   INVENTORY MANAGEMENT SYSTEM");
        System.out.println("   ICT711 - Group Project");
        System.out.println("==========================================");

        // Load existing data from file
        manager.loadFromFile(DATA_FILE);

        boolean running = true;
        while (running) {
            displayMenu();
            int choice = getMenuChoice();

            switch (choice) {
                case 1:
                    addNewItem();
                    break;
                case 2:
                    viewAllItems();
                    break;
                case 3:
                    searchItem();
                    break;
                case 4:
                    updateItem();
                    break;
                case 5:
                    deleteItem();
                    break;
                case 6:
                    runEvaluation();
                    break;
                case 7:
                    processAlerts();
                    break;
                case 8:
                    viewHistory();
                    break;
                case 9:
                    viewInventoryValue();
                    break;
                case 10:
                    // Save data before exiting
                    manager.saveToFile(DATA_FILE);
                    System.out.println("Thank you for using the Inventory Management System. Goodbye!");
                    running = false;
                    break;
                default:
                    System.out.println("Invalid option. Please choose between 1 and 10.");
            }
        }
        scanner.close();
    }

    // Shows the main menu options
    private static void displayMenu() {
        System.out.println("\n------ MAIN MENU ------");
        System.out.println("1.  Add New Item");
        System.out.println("2.  View All Items");
        System.out.println("3.  Search Item");
        System.out.println("4.  Update Item");
        System.out.println("5.  Delete Item");
        System.out.println("6.  Run Stock Evaluation");
        System.out.println("7.  Process Pending Alerts");
        System.out.println("8.  View Review History");
        System.out.println("9.  View Total Inventory Value");
        System.out.println("10. Save & Exit");
        System.out.println("-----------------------");
        System.out.print("Enter your choice: ");
    }

    // Gets menu choice with error handling for invalid input
    private static int getMenuChoice() {
        try {
            int choice = scanner.nextInt();
            scanner.nextLine(); // clear the newline
            return choice;
        } catch (InputMismatchException e) {
            scanner.nextLine(); // clear invalid input
            return -1;
        }
    }

    // ==================== MENU OPTION METHODS ====================

    // Option 1: Add new item
    private static void addNewItem() {
        System.out.println("\n--- Add New Item ---");
        System.out.println("Select item category:");
        System.out.println("1. Electronics");
        System.out.println("2. Grocery");
        System.out.println("3. Clothing");
        System.out.print("Choice: ");

        int catChoice = getMenuChoice();

        // collect common fields
        System.out.print("Enter Item ID: ");
        String id = scanner.nextLine().trim();
        System.out.print("Enter Item Name: ");
        String name = scanner.nextLine().trim();
        System.out.print("Enter Supplier: ");
        String supplier = scanner.nextLine().trim();

        double price = 0;
        int qty = 0;
        try {
            System.out.print("Enter Price: ");
            price = Double.parseDouble(scanner.nextLine().trim());
            System.out.print("Enter Quantity: ");
            qty = Integer.parseInt(scanner.nextLine().trim());
        } catch (NumberFormatException e) {
            System.out.println("Invalid number entered. Item not added.");
            return;
        }

        Item newItem = null;

        switch (catChoice) {
            case 1:
                try {
                    System.out.print("Enter Warranty (months): ");
                    int warranty = Integer.parseInt(scanner.nextLine().trim());
                    System.out.print("Enter Brand: ");
                    String brand = scanner.nextLine().trim();
                    newItem = new ElectronicsItem(id, name, supplier, price, qty, warranty, brand);
                } catch (NumberFormatException e) {
                    System.out.println("Invalid warranty value. Item not added.");
                    return;
                }
                break;
            case 2:
                System.out.print("Enter Expiry Date (YYYY-MM-DD): ");
                String expiry = scanner.nextLine().trim();
                System.out.print("Is it Organic? (true/false): ");
                boolean organic = Boolean.parseBoolean(scanner.nextLine().trim());
                newItem = new GroceryItem(id, name, supplier, price, qty, expiry, organic);
                break;
            case 3:
                System.out.print("Enter Size (S/M/L/XL): ");
                String size = scanner.nextLine().trim();
                System.out.print("Enter Material: ");
                String material = scanner.nextLine().trim();
                newItem = new ClothingItem(id, name, supplier, price, qty, size, material);
                break;
            default:
                System.out.println("Invalid category choice. Item not added.");
                return;
        }

        if (newItem != null) {
            manager.addItem(newItem);
        }
    }

    // Option 2: View all items
    private static void viewAllItems() {
        manager.displayAllItems();
    }

    // Option 3: Search for items
    private static void searchItem() {
        System.out.println("\n--- Search Item ---");
        System.out.println("Search by:");
        System.out.println("1. Item ID");
        System.out.println("2. Item Name");
        System.out.println("3. Category");
        System.out.print("Choice: ");

        int searchChoice = getMenuChoice();

        switch (searchChoice) {
            case 1:
                System.out.print("Enter Item ID: ");
                String searchId = scanner.nextLine().trim();
                Item found = manager.searchById(searchId);
                if (found != null) {
                    System.out.println("\nItem found:");
                    System.out.println(found.displayDetails());
                } else {
                    System.out.println("No item found with ID: " + searchId);
                }
                break;
            case 2:
                System.out.print("Enter Item Name (or part of name): ");
                String searchName = scanner.nextLine().trim();
                ArrayList<Item> nameResults = manager.searchByName(searchName);
                if (!nameResults.isEmpty()) {
                    System.out.println("\nFound " + nameResults.size() + " item(s):");
                    for (Item item : nameResults) {
                        System.out.println(item.displayDetails());
                    }
                } else {
                    System.out.println("No items found matching: " + searchName);
                }
                break;
            case 3:
                System.out.println("Enter Category (Electronics/Grocery/Clothing): ");
                String searchCat = scanner.nextLine().trim();
                ArrayList<Item> catResults = manager.searchByCategory(searchCat);
                if (!catResults.isEmpty()) {
                    System.out.println("\nFound " + catResults.size() + " item(s) in " + searchCat + ":");
                    for (Item item : catResults) {
                        System.out.println(item.displayDetails());
                    }
                } else {
                    System.out.println("No items found in category: " + searchCat);
                }
                break;
            default:
                System.out.println("Invalid search option.");
        }
    }

    // Option 4: Update an item
    private static void updateItem() {
        System.out.println("\n--- Update Item ---");
        System.out.print("Enter Item ID to update: ");
        String id = scanner.nextLine().trim();

        Item item = manager.searchById(id);
        if (item == null) {
            System.out.println("No item found with ID: " + id);
            return;
        }

        System.out.println("Current details: " + item.displayDetails());
        System.out.println("Enter new values (press Enter to keep current value):");

        System.out.print("New Name [" + item.getItemName() + "]: ");
        String newName = scanner.nextLine().trim();
        if (newName.isEmpty()) newName = item.getItemName();

        System.out.print("New Supplier [" + item.getSupplier() + "]: ");
        String newSupplier = scanner.nextLine().trim();
        if (newSupplier.isEmpty()) newSupplier = item.getSupplier();

        double newPrice = item.getPrice();
        System.out.print("New Price [" + item.getPrice() + "]: ");
        String priceInput = scanner.nextLine().trim();
        if (!priceInput.isEmpty()) {
            try {
                newPrice = Double.parseDouble(priceInput);
            } catch (NumberFormatException e) {
                System.out.println("Invalid price. Keeping current value.");
            }
        }

        int newQty = item.getQuantity();
        System.out.print("New Quantity [" + item.getQuantity() + "]: ");
        String qtyInput = scanner.nextLine().trim();
        if (!qtyInput.isEmpty()) {
            try {
                newQty = Integer.parseInt(qtyInput);
            } catch (NumberFormatException e) {
                System.out.println("Invalid quantity. Keeping current value.");
            }
        }

        manager.updateItem(id, newName, newSupplier, newPrice, newQty);
    }

    // Option 5: Delete an item
    private static void deleteItem() {
        System.out.println("\n--- Delete Item ---");
        System.out.print("Enter Item ID to delete: ");
        String id = scanner.nextLine().trim();

        Item item = manager.searchById(id);
        if (item == null) {
            System.out.println("No item found with ID: " + id);
            return;
        }

        System.out.println("Item to delete: " + item.displayDetails());
        System.out.print("Are you sure? (yes/no): ");
        String confirm = scanner.nextLine().trim();

        if (confirm.equalsIgnoreCase("yes")) {
            manager.deleteItem(id);
        } else {
            System.out.println("Deletion cancelled.");
        }
    }

    // Option 6: Run stock evaluation
    private static void runEvaluation() {
        manager.runStockEvaluation();
    }

    // Option 7: Process pending alerts
    private static void processAlerts() {
        manager.processPendingAlerts();
    }

    // Option 8: View review history
    private static void viewHistory() {
        manager.viewReviewHistory();
    }

    // Option 9: Show total inventory value
    private static void viewInventoryValue() {
        double totalValue = manager.getTotalInventoryValue();
        System.out.println("\n===== INVENTORY SUMMARY =====");
        System.out.println("Total Items: " + manager.getItemCount());
        System.out.println("Total Inventory Value: $" + String.format("%.2f", totalValue));
        System.out.println("=============================\n");
    }
}
